# Server
PORT=3000

# Default coding agent: claude-code, opencode, or codex
DEFAULT_AGENT=claude-code

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=

# Discord Bot Token
DISCORD_BOT_TOKEN=

# iMessage (macOS only)
IMESSAGE_ENABLED=false

# Claude Code API Key (if not set in environment)
ANTHROPIC_API_KEY=
