{
  "name": "@codey/gateway",
  "version": "0.1.0",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codey": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "cd ../.. && node packages/gateway/dist/index.js",
    "dev": "cd ../.. && ts-node packages/gateway/src/index.ts",
    "watch": "tsc --watch",
    "configure": "cd ../.. && ts-node packages/gateway/src/index.ts configure",
    "status": "cd ../.. && ts-node packages/gateway/src/index.ts status",
    "set-agent": "cd ../.. && ts-node packages/gateway/src/index.ts set-agent",
    "set-model": "cd ../.. && ts-node packages/gateway/src/index.ts set-model",
    "tui": "cd ../.. && ts-node packages/gateway/src/index.ts tui"
  },
  "dependencies": {
    "@codey/core": "*",
    "discord.js": "^14.0.0",
    "dotenv": "^16.0.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "node-telegram-bot-api": "^0.64.0",
    "undici": "^5.28.0"
  },
  "devDependencies": {
    "@types/node-telegram-bot-api": "^0.64.13",
    "typescript": "^5.9.0"
  }
}
