{
  "gateway": {
    "port": 3000,
    "defaultAgent": "claude-code"
  },
  "channels": {
    "telegram": {
      "enabled": false,
      "botToken": "",
      "notifyChatId": ""
    },
    "discord": {
      "enabled": false,
      "botToken": ""
    },
    "imessage": {
      "enabled": false
    }
  },
  "agents": {
    "claude-code": {
      "enabled": true,
      "provider": "anthropic",
      "defaultModel": "claude-sonnet-4-20250514",
      "models": [
        "claude-sonnet-4-20250514",
        "claude-opus-4-20250514",
        "claude-3-5-sonnet-20241022"
      ]
    },
    "opencode": {
      "enabled": true,
      "provider": "openai",
      "defaultModel": "gpt-4.1",
      "models": [
        "gpt-4.1",
        "gpt-4o",
        "o4-mini"
      ]
    },
    "codex": {
      "enabled": true,
      "provider": "openai",
      "defaultModel": "gpt-5-codex",
      "models": [
        "gpt-5-codex",
        "gpt-4.1"
      ]
    }
  },
  "profiles": [
    {
      "name": "default",
      "anthropic": { "apiKey": "", "baseUrl": "" },
      "openai": { "apiKey": "", "baseUrl": "" },
      "google": { "apiKey": "" }
    }
  ],
  "activeProfile": "default",
  "planner": {
    "enabled": true,
    "model": "claude-sonnet-4-20250514",
    "maxPlanTokens": 1500,
    "minPromptLength": 80
  },
  "context": {
    "maxTokenBudget": 12000,
    "maxTurns": 30,
    "ttlMinutes": 60
  },
  "memory": {
    "enabled": true,
    "autoExtract": true
  },
  "dev": {
    "logLevel": "info",
    "logFile": "gateway.log"
  }
}
