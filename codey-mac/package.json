{
  "name": "codey-mac",
  "version": "0.3.1",
  "description": "Codey - macOS menu bar application for coding agents",
  "main": "dist-electron/main.js",
  "author": "its-ahoh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/its-ahoh/codey.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && electron-builder",
    "build:mac": "vite build && electron-builder --mac",
    "build:mac:signed": "vite build && electron-builder --mac --publish never",
    "preview": "vite preview"
  },
  "dependencies": {
    "@codey/core": "*",
    "@codey/gateway": "*",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "28.3.3",
    "electron-builder": "^24.9.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5"
  },
  "build": {
    "appId": "com.codey.mac",
    "productName": "Codey",
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist",
      "identity": "ou zixian (N59NN58KB2)",
      "notarize": {
        "teamId": "N59NN58KB2"
      }
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      { "from": "build/trayIconTemplate.png", "to": "trayIconTemplate.png" },
      { "from": "build/trayIconTemplate@2x.png", "to": "trayIconTemplate@2x.png" },
      { "from": "../workers", "to": "bundled-workers", "filter": ["**/*"] }
    ]
  }
}
