{
  "name": "codey-mac",
  "version": "0.10.1",
  "description": "Codey - macOS menu bar application for coding agents",
  "main": "dist-electron/main.js",
  "author": "its-ahoh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/its-ahoh/codey.git"
  },
  "scripts": {
    "postinstall": "node scripts/ensure-node-pty.cjs",
    "dev": "vite",
    "build:helper": "cd ../voice && make helper",
    "prebuild": "npm run build:helper",
    "prebuild:mac": "npm run build:helper",
    "prebuild:mac:local": "npm run build:helper",
    "prebuild:mac:signed": "npm run build:helper",
    "build": "vite build && electron-builder",
    "build:mac": "vite build && electron-builder --mac",
    "build:mac:local": "vite build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac dir --publish never --config.directories.output=release-local --config.mac.identity=null && codesign --force --deep --sign - --options runtime --entitlements build/entitlements.mac.local.plist release-local/mac-arm64/Codey.app",
    "build:mac:signed": "vite build && electron-builder --mac --publish never",
    "notarize:mac": "node build/notarize-dist.js",
    "dist:mac": "node build/dist-mac.js",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "@codey/core": "*",
    "@codey/gateway": "*",
    "@types/qrcode": "^1.5.6",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "@xyflow/react": "^12.11.0",
    "electron-updater": "^6.8.3",
    "highlight.js": "^10.7.3",
    "node-pty": "^1.1.0",
    "qrcode": "^1.5.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron/notarize": "^2.2.1",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "electron": "41.10.2",
    "electron-builder": "26.15.3",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.5",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.codey.mac",
    "productName": "Codey",
    "asarUnpack": [
      "node_modules/node-pty/**/*"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "identity": "ou zixian (N59NN58KB2)",
      "notarize": false,
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Codey transcribes your speech into text at your cursor when you use voice input.",
        "NSCameraUsageDescription": "Codey lets websites use your camera only after you approve the site permission.",
        "NSLocationUsageDescription": "Codey lets websites use your location only after you approve the site permission.",
        "NSAppleEventsUsageDescription": "Codey pastes transcribed voice text into the focused app via System Events."
      }
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "its-ahoh",
      "repo": "codey",
      "releaseType": "release"
    },
    "extraResources": [
      {
        "from": "build/trayIconTemplate.png",
        "to": "trayIconTemplate.png"
      },
      {
        "from": "build/trayIconTemplate@2x.png",
        "to": "trayIconTemplate@2x.png"
      },
      {
        "from": "../workers",
        "to": "bundled-workers",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../voice/CodeyVoice",
        "to": "CodeyVoice"
      },
      {
        "from": "electron/browser-agent-cli.cjs",
        "to": "browser-agent-cli.cjs"
      },
      {
        "from": "electron/browser-mcp-server.cjs",
        "to": "browser-mcp-server.cjs"
      }
    ]
  }
}
